# Copy this file to ".env" and fill in real values. NEVER commit ".env".
#
# Use TEST credentials for development (rzp_test_...). Only switch to LIVE
# credentials (rzp_live_...) on the deployed production server.

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret_here

# Port this API listens on.
PORT=8787

# The web app's origin, for CORS. Vite dev default shown.
ALLOWED_ORIGIN=http://localhost:5176

# Optional. Set a long random string to enable GET /api/orders
# and the /admin page. Callers send it in the "x-admin-token" header.
ADMIN_TOKEN=

# Optional but recommended. From Razorpay Dashboard → Webhooks. This is a
# SEPARATE secret from the Key Secret. Enables POST /api/razorpay/webhook
# as a payment-confirmation backstop. Subscribe to "payment.captured"
# (and/or "order.paid") and point the webhook at /api/razorpay/webhook.
RAZORPAY_WEBHOOK_SECRET=

# Optional: order-confirmation emails. If unset, emails are skipped (the
# payment flow still works). For Gmail use an App Password, not your login.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your_app_password
MAIL_FROM=Hummusapiens <you@example.com>
OWNER_EMAIL=you@example.com
